<!doctype html>
<html class="scroll-smooth overflow-x-hidden" lang="{{ site.locale|default('ru') }}">
<head>
    {% set pageMeta = page.meta is defined ? page.meta : null %}
    {% set siteUrl = site.url|default('') %}
    {% set metaTitle = pageMeta ? pageMeta.title : site.meta.title|default('БИОФАРМ') %}
    {% set metaDescription = pageMeta ? pageMeta.description : site.meta.description|default('Натуральные продукты БИОФАРМ.') %}
    {% set canonicalUrl = pageMeta and pageMeta.canonicalUrl ? pageMeta.canonicalUrl : null %}
    {% set robots = pageMeta ? pageMeta.robots : 'index, follow' %}
    {% set ogTitle = pageMeta and pageMeta.ogTitle ? pageMeta.ogTitle : metaTitle %}
    {% set ogDescription = pageMeta and pageMeta.ogDescription ? pageMeta.ogDescription : metaDescription %}
    {% set ogType = pageMeta and pageMeta.ogType ? pageMeta.ogType : 'website' %}
    {% set defaultOgImage = site_setting('site_default_og_image', site.meta.ogImage|default(null)) %}
    {% set ogImage = pageMeta and pageMeta.ogImage ? pageMeta.ogImage : defaultOgImage %}
    {% if ogImage and siteUrl and ogImage starts with '/' %}
        {% set ogImage = siteUrl ~ ogImage %}
    {% endif %}
    {% set ogImageAlt = pageMeta and pageMeta.ogImageAlt ? pageMeta.ogImageAlt : ogTitle %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ metaTitle }}{% endblock %}</title>
    <meta name="description" content="{% block description %}{{ metaDescription }}{% endblock %}">
    <meta name="robots" content="{{ robots }}">
    {% if canonicalUrl %}
        <link rel="canonical" href="{{ canonicalUrl }}">
    {% endif %}
    <meta property="og:locale" content="ru_RU">
    <meta property="og:site_name" content="{{ site_setting('site_name', site.brand.title|default('БИОФАРМ')) }}">
    <meta property="og:type" content="{{ ogType }}">
    <meta property="og:title" content="{{ ogTitle }}">
    <meta property="og:description" content="{{ ogDescription }}">
    {% if canonicalUrl %}
        <meta property="og:url" content="{{ canonicalUrl }}">
    {% endif %}
    {% if ogImage %}
        <meta property="og:image" content="{{ ogImage }}">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
        <meta property="og:image:alt" content="{{ ogImageAlt }}">
    {% endif %}
    {% if pageMeta and pageMeta.jsonLd %}
        {% for schema in pageMeta.jsonLd %}
            <script type="application/ld+json">{{ schema|json_encode|raw }}</script>
        {% endfor %}
    {% endif %}
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ vite_asset('assets/styles/app.css') }}">
    {% endblock %}
</head>
<body class="overflow-x-hidden bg-background font-sans text-foreground antialiased">
    {% include 'components/layout/header.html.twig' with { site: site } only %}

    <main class="min-h-screen">
        {% block content %}{% endblock %}
    </main>

    {% include 'components/layout/footer.html.twig' only %}

    {% block javascripts %}
        <script type="module" src="{{ vite_asset('assets/react/mount.tsx') }}"></script>
    {% endblock %}
</body>
</html>
