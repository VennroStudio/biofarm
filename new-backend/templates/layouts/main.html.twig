<!doctype html>
<html class="scroll-smooth overflow-x-hidden" lang="{{ site.locale|default('ru') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ site.meta.title|default('БИОФАРМ') }}{% endblock %}</title>
    <meta name="description" content="{% block description %}{{ site.meta.description|default('PHP/Twig frontend with React islands.') }}{% endblock %}">
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ vite_asset('assets/styles/app.css') }}">
    {% endblock %}
</head>
<body class="overflow-x-hidden bg-background font-sans text-foreground antialiased">
    {% include 'components/layout/header.html.twig' with { site: site } only %}

    <main class="min-h-screen">
        {% block content %}{% endblock %}
    </main>

    {% include 'components/layout/footer.html.twig' only %}

    {% block javascripts %}
        <script type="module" src="{{ vite_asset('assets/react/mount.tsx') }}"></script>
    {% endblock %}
</body>
</html>
