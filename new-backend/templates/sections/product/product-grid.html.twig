<section class="section" id="catalog">
    {% include 'components/ui/section-head.html.twig' with {
        eyebrow: 'Каталог',
        title: selectedCategory ? 'Категория: ' ~ selectedCategory : 'Каталог продукции',
    } only %}

    <div class="product-grid">
        {% for product in products %}
            {% include 'components/product/card.html.twig' with { product: product } only %}
        {% else %}
            {% include 'components/ui/empty-state.html.twig' with {
                title: 'Товары пока не добавлены',
                message: selectedCategory
                    ? 'В выбранной категории пока нет товаров.'
                    : 'Каталог наполнится после миграции базы данных.',
            } only %}
        {% endfor %}
    </div>
</section>
