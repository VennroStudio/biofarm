{% if product %}
    <div class="bg-muted/30 pb-4 pt-24">
        <div class="container mx-auto px-4">
            <nav class="flex items-center gap-2 text-sm text-muted-foreground" aria-label="Хлебные крошки">
                <a class="transition-colors hover:text-primary" href="/">Главная</a>
                <span aria-hidden="true">/</span>
                <a class="transition-colors hover:text-primary" href="/catalog">Каталог</a>
                <span aria-hidden="true">/</span>
                <span class="text-foreground">{{ product.title }}</span>
            </nav>
        </div>
    </div>

    <section class="py-12">
        <div class="container mx-auto px-4">
            <div class="grid gap-12 lg:grid-cols-2">
                <div data-reveal data-reveal-x="-30" data-reveal-y="0" data-reveal-duration="600">
                    <div class="flex gap-4" data-product-gallery>
                        {% if product.images|length > 1 %}
                            <div class="flex h-full w-20 flex-shrink-0 flex-col gap-2">
                                <button
                                    class="inline-flex h-8 w-full items-center justify-center gap-2 whitespace-nowrap rounded-lg text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0"
                                    type="button"
                                    aria-label="Предыдущее фото"
                                    data-product-gallery-up
                                >
                                    <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="m18 15-6-6-6 6"></path>
                                    </svg>
                                </button>

                                <div class="flex min-h-0 flex-1 flex-col justify-start gap-2">
                                    {% for image in product.images|slice(0, 4) %}
                                        <button
                                            class="{{ loop.first ? 'border-primary ring-2 ring-primary/20' : 'border-transparent hover:border-muted-foreground/30' }} min-h-0 w-full flex-1 flex-shrink-0 overflow-hidden rounded-lg border-2 transition-all duration-200"
                                            type="button"
                                            aria-label="Показать фото {{ loop.index }}"
                                            data-product-gallery-thumb
                                            data-gallery-index="{{ loop.index0 }}"
                                        >
                                            <img
                                                src="{{ image }}"
                                                alt="{{ product.title }} - фото {{ loop.index }}"
                                                class="h-full w-full object-cover"
                                                loading="{{ loop.first ? 'eager' : 'lazy' }}"
                                                decoding="async"
                                            >
                                        </button>
                                    {% endfor %}
                                </div>

                                <button
                                    class="inline-flex h-8 w-full items-center justify-center gap-2 whitespace-nowrap rounded-lg text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0"
                                    type="button"
                                    aria-label="Следующее фото"
                                    data-product-gallery-down
                                >
                                    <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </button>
                            </div>
                        {% endif %}

                        <div class="flex-1">
                            <button
                                class="group relative aspect-square w-full cursor-zoom-in overflow-hidden rounded-2xl bg-muted text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                                type="button"
                                aria-label="Открыть фото товара"
                                data-product-gallery-open
                            >
                                <img
                                    class="h-full w-full object-contain"
                                    src="{{ product.images[0] }}"
                                    alt="{{ product.title }}"
                                    loading="eager"
                                    fetchpriority="high"
                                    decoding="async"
                                    data-product-gallery-main
                                >
                                {% if product.badge %}
                                    <span class="absolute left-4 top-4 rounded-full bg-accent px-4 py-2 text-base font-medium text-accent-foreground">
                                        {{ product.badge }}
                                    </span>
                                {% endif %}
                                <span class="absolute inset-0 flex items-center justify-center bg-black/0 transition-colors group-hover:bg-black/10">
                                    <span class="rounded-full bg-white/90 p-3 opacity-0 transition-opacity group-hover:opacity-100">
                                        <svg class="h-6 w-6 text-foreground" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="11" cy="11" r="8"></circle>
                                            <path d="m21 21-4.35-4.35"></path>
                                            <path d="M11 8v6"></path>
                                            <path d="M8 11h6"></path>
                                        </svg>
                                    </span>
                                </span>
                            </button>
                        </div>

                        <div
                            class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95"
                            role="dialog"
                            aria-modal="true"
                            aria-label="Галерея товара"
                            aria-hidden="true"
                            tabindex="-1"
                            data-product-gallery-lightbox
                        >
                            <button
                                class="absolute right-4 top-4 inline-flex h-10 w-10 items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium text-white ring-offset-background transition-colors hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0"
                                type="button"
                                aria-label="Закрыть галерею"
                                data-product-gallery-close
                            >
                                <svg class="h-6 w-6" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M18 6 6 18"></path>
                                    <path d="m6 6 12 12"></path>
                                </svg>
                            </button>

                            {% if product.images|length > 1 %}
                                <button
                                    class="absolute left-4 top-1/2 inline-flex h-12 w-12 -translate-y-1/2 items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium text-white ring-offset-background transition-colors hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0"
                                    type="button"
                                    aria-label="Предыдущее фото"
                                    data-product-gallery-prev
                                >
                                    <svg class="h-8 w-8" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="m15 18-6-6 6-6"></path>
                                    </svg>
                                </button>
                                <button
                                    class="absolute right-4 top-1/2 inline-flex h-12 w-12 -translate-y-1/2 items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium text-white ring-offset-background transition-colors hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0"
                                    type="button"
                                    aria-label="Следующее фото"
                                    data-product-gallery-next
                                >
                                    <svg class="h-8 w-8" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="m9 18 6-6-6-6"></path>
                                    </svg>
                                </button>
                            {% endif %}

                            <img
                                src="{{ product.images[0] }}"
                                alt="{{ product.title }}"
                                class="max-h-[90vh] max-w-[90vw] object-contain"
                                data-product-gallery-lightbox-image
                            >

                            {% if product.images|length > 1 %}
                                <div class="absolute bottom-4 left-1/2 flex -translate-x-1/2 gap-2">
                                    {% for image in product.images %}
                                        <button
                                            class="{{ loop.first ? 'border-white opacity-100' : 'border-transparent opacity-60 hover:opacity-100' }} h-16 w-16 overflow-hidden rounded-lg border-2 transition-all"
                                            type="button"
                                            aria-label="Показать фото {{ loop.index }}"
                                            data-product-gallery-lightbox-thumb
                                            data-gallery-index="{{ loop.index0 }}"
                                        >
                                            <img src="{{ image }}" alt="" class="h-full w-full object-cover" loading="lazy" decoding="async">
                                        </button>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div
                            data-react-island="product-gallery"
                            data-root-selector="[data-product-gallery]"
                            data-images="{{ product.images|json_encode|e('html_attr') }}"
                            data-product-name="{{ product.title }}"
                            hidden
                        ></div>
                    </div>
                </div>

                <div data-reveal data-reveal-x="30" data-reveal-y="0" data-reveal-duration="600">
                    <div class="lg:sticky lg:top-28">
                        <h1 class="mb-4 font-display text-3xl font-bold text-foreground md:text-4xl">
                            {{ product.title }}
                        </h1>

                        {% if product.shortDescription %}
                            <p class="mb-6 text-lg text-muted-foreground">{{ product.shortDescription }}</p>
                        {% endif %}

                        <div class="mb-6 space-y-2">
                            <span class="block font-medium text-accent">{{ product.weight }}</span>
                            {% if product.ingredients %}
                                <p class="text-sm text-muted-foreground">Состав: {{ product.ingredients }}</p>
                            {% endif %}
                        </div>

                        <div class="mb-6 flex flex-wrap items-center gap-4">
                            <span class="text-4xl font-bold text-primary">{{ product.price|number_format(0, '.', ' ') }} ₽</span>
                            {% if product.oldPrice %}
                                <span class="text-xl text-muted-foreground line-through">{{ product.oldPrice|number_format(0, '.', ' ') }} ₽</span>
                                <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-semibold text-red-600">
                                    -{{ ((1 - product.price / product.oldPrice) * 100)|round }}%
                                </span>
                            {% endif %}
                        </div>

                        <div class="mb-6 flex flex-col gap-3 sm:flex-row">
                            <button class="inline-flex h-11 items-center justify-center gap-2 whitespace-nowrap rounded-md border border-input bg-background px-8 text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0" type="button" aria-label="Добавить в избранное">
                                <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
                                </svg>
                            </button>
                            <button class="inline-flex h-11 items-center justify-center gap-2 whitespace-nowrap rounded-md border border-input bg-background px-8 text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0" type="button" aria-label="Поделиться товаром">
                                <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="18" cy="5" r="3"></circle>
                                    <circle cx="6" cy="12" r="3"></circle>
                                    <circle cx="18" cy="19" r="3"></circle>
                                    <path d="m8.59 13.51 6.83 3.98"></path>
                                    <path d="m15.41 6.51-6.82 3.98"></path>
                                </svg>
                            </button>
                        </div>

                        {% if product.wbLink or product.ozonLink %}
                            <div class="mb-8 flex flex-col gap-3 sm:flex-row">
                                {% if product.wbLink %}
                                    <a href="{{ product.wbLink }}" target="_blank" rel="noopener noreferrer" class="flex-1">
                                        <span class="inline-flex h-10 w-full items-center justify-center gap-2 whitespace-nowrap rounded-md border border-purple-300 bg-background px-4 py-2 text-sm font-medium text-purple-600 ring-offset-background transition-colors hover:bg-purple-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0">
                                            <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M15 3h6v6"></path>
                                                <path d="M10 14 21 3"></path>
                                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                            </svg>
                                            Купить на Wildberries
                                        </span>
                                    </a>
                                {% endif %}
                                {% if product.ozonLink %}
                                    <a href="{{ product.ozonLink }}" target="_blank" rel="noopener noreferrer" class="flex-1">
                                        <span class="inline-flex h-10 w-full items-center justify-center gap-2 whitespace-nowrap rounded-md border border-blue-300 bg-background px-4 py-2 text-sm font-medium text-blue-600 ring-offset-background transition-colors hover:bg-blue-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0">
                                            <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M15 3h6v6"></path>
                                                <path d="M10 14 21 3"></path>
                                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                            </svg>
                                            Купить на Ozon
                                        </span>
                                    </a>
                                {% endif %}
                            </div>
                        {% endif %}

                        <div class="my-6 h-px bg-border"></div>

                        {% if product.features is not empty %}
                            <div class="mb-6">
                                <h3 class="mb-3 font-semibold text-foreground">Особенности:</h3>
                                <ul class="space-y-2">
                                    {% for feature in product.features %}
                                        <li class="flex items-center gap-2 text-muted-foreground">
                                            <svg class="h-4 w-4 text-primary" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M20 6 9 17l-5-5"></path>
                                            </svg>
                                            {{ feature }}
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}

                        <div class="mt-8 grid grid-cols-3 gap-4">
                            <div class="rounded-xl bg-muted/50 p-4 text-center">
                                <svg class="mx-auto mb-2 h-6 w-6 text-primary" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M10 17h4V5H2v12h3"></path>
                                    <path d="M14 17h1"></path>
                                    <path d="M19 17h3v-6h-3.5L16 8h-2"></path>
                                    <circle cx="7.5" cy="17.5" r="2.5"></circle>
                                    <circle cx="17.5" cy="17.5" r="2.5"></circle>
                                </svg>
                                <span class="text-sm text-muted-foreground">Быстрая доставка</span>
                            </div>
                            <div class="rounded-xl bg-muted/50 p-4 text-center">
                                <svg class="mx-auto mb-2 h-6 w-6 text-primary" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                                </svg>
                                <span class="text-sm text-muted-foreground">Гарантия качества</span>
                            </div>
                            <div class="rounded-xl bg-muted/50 p-4 text-center">
                                <svg class="mx-auto mb-2 h-6 w-6 text-primary" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                                    <path d="M3 3v5h5"></path>
                                </svg>
                                <span class="text-sm text-muted-foreground">Возврат 14 дней</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-16" data-reveal data-reveal-duration="600" data-reveal-delay="200">
                <h2 class="mb-6 font-display text-2xl font-bold text-foreground">Описание</h2>
                <div class="mb-8 max-w-none text-muted-foreground [&_a]:text-primary [&_a:hover]:underline [&_h2]:mb-6 [&_h2]:mt-12 [&_h2]:font-display [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-foreground [&_h3]:mb-4 [&_h3]:mt-8 [&_h3]:font-display [&_h3]:text-xl [&_h3]:font-bold [&_h3]:text-foreground [&_li]:my-2 [&_ol]:my-6 [&_p]:mb-6 [&_p]:leading-relaxed [&_strong]:font-semibold [&_strong]:text-foreground [&_ul]:my-6">
                    {{ product.descriptionHtml|raw }}
                </div>
            </div>
        </div>
    </section>

    {% if relatedProducts|default([]) is not empty %}
        <section class="bg-muted/30 py-16">
            <div class="container mx-auto px-4">
                <h2 class="mb-8 font-display text-2xl font-bold text-foreground">
                    Похожие товары
                </h2>
                <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                    {% for relatedProduct in relatedProducts %}
                        {% include 'components/product/card.html.twig' with {
                            product: relatedProduct,
                            revealDelay: loop.index0 * 100,
                        } only %}
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}
{% endif %}
