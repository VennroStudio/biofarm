<section id="partner" class="bg-secondary/30 py-20 lg:py-32">
    <div class="container mx-auto px-4">
        <div class="grid items-start gap-16 lg:grid-cols-2">
            <div>
                <span class="mb-4 inline-block font-medium text-accent" data-reveal>
                    Сотрудничество с нами
                </span>
                <h2 class="mb-12 font-display text-3xl font-bold text-foreground md:text-4xl" data-reveal data-reveal-delay="150">
                    Мы рады надежным партнерам!
                </h2>

                <div class="grid gap-6 sm:grid-cols-2">
                    <article class="rounded-lg bg-card p-6 shadow-premium transition-shadow hover:shadow-premium-lg" data-reveal data-reveal-delay="300">
                        <div class="gradient-primary mb-4 flex h-12 w-12 items-center justify-center rounded-lg">
                            <svg class="h-6 w-6 text-primary-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                                <path d="M11 20A7 7 0 0 1 4 13c0-6 8-9 16-9 0 8-3 16-9 16Z"></path>
                                <path d="M4 13c3 0 6 0 9-3"></path>
                            </svg>
                        </div>
                        <h3 class="mb-2 text-lg font-bold text-foreground">100% натуральная продукция</h3>
                        <p class="text-sm text-muted-foreground">
                            Мы уверены в качестве своего продукта, поэтому смело отправляем пробную партию!
                        </p>
                    </article>

                    <article class="rounded-lg bg-card p-6 shadow-premium transition-shadow hover:shadow-premium-lg" data-reveal data-reveal-delay="450">
                        <div class="gradient-primary mb-4 flex h-12 w-12 items-center justify-center rounded-lg">
                            <svg class="h-6 w-6 text-primary-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                                <path d="M12 15a6 6 0 1 0 0-12 6 6 0 0 0 0 12Z"></path>
                                <path d="M9 14.5 7 22l5-3 5 3-2-7.5"></path>
                            </svg>
                        </div>
                        <h3 class="mb-2 text-lg font-bold text-foreground">Сертифицировано</h3>
                        <p class="text-sm text-muted-foreground">
                            Вся продукция сертифицирована и соответствует высшим стандартам качества.
                        </p>
                    </article>

                    <article class="rounded-lg bg-card p-6 shadow-premium transition-shadow hover:shadow-premium-lg" data-reveal data-reveal-delay="600">
                        <div class="gradient-primary mb-4 flex h-12 w-12 items-center justify-center rounded-lg">
                            <svg class="h-6 w-6 text-primary-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                                <path d="M10 17h4V5H2v12h3"></path>
                                <path d="M14 17h1"></path>
                                <path d="M19 17h3v-6h-3.5L16 8h-2"></path>
                                <circle cx="7.5" cy="17.5" r="2.5"></circle>
                                <circle cx="17.5" cy="17.5" r="2.5"></circle>
                            </svg>
                        </div>
                        <h3 class="mb-2 text-lg font-bold text-foreground">Без предоплаты</h3>
                        <p class="text-sm text-muted-foreground">
                            Поставка на реализацию на месяц без предоплаты: продали — оплатили — повторяем.
                        </p>
                    </article>

                    <article class="rounded-lg bg-card p-6 shadow-premium transition-shadow hover:shadow-premium-lg" data-reveal data-reveal-delay="750">
                        <div class="gradient-primary mb-4 flex h-12 w-12 items-center justify-center rounded-lg">
                            <svg class="h-6 w-6 text-primary-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                                <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                            </svg>
                        </div>
                        <h3 class="mb-2 text-lg font-bold text-foreground">Гарантия качества</h3>
                        <p class="text-sm text-muted-foreground">
                            Не продадите — заберём товар обратно. Без оплат, комиссий и штрафов.
                        </p>
                    </article>
                </div>
            </div>

            <div class="rounded-2xl bg-card p-8 shadow-premium-lg lg:p-10" data-reveal data-reveal-x="30" data-reveal-y="0" data-reveal-duration="800" data-reveal-delay="300">
                <h3 class="mb-2 font-display text-2xl font-bold text-foreground">
                    Остались вопросы?
                </h3>
                <p class="mb-8 text-muted-foreground">
                    Заполните форму и мы свяжемся с вами в ближайшее время
                </p>

                <form class="space-y-6" method="post" action="/feedback">
                    <div class="grid gap-4 sm:grid-cols-2">
                        <div>
                            <label class="mb-2 block text-sm font-medium text-foreground" for="partner-name">
                                Ваше имя
                            </label>
                            <input
                                id="partner-name"
                                class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 md:text-sm"
                                type="text"
                                name="name"
                                placeholder="Иван Иванов"
                                autocomplete="name"
                                required
                            >
                        </div>
                        <div>
                            <label class="mb-2 block text-sm font-medium text-foreground" for="partner-phone">
                                Телефон
                            </label>
                            <input
                                id="partner-phone"
                                class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 md:text-sm"
                                type="tel"
                                name="phone"
                                placeholder="+7 (999) 123-45-67"
                                autocomplete="tel"
                            >
                        </div>
                    </div>

                    <div>
                        <label class="mb-2 block text-sm font-medium text-foreground" for="partner-email">
                            Email
                        </label>
                        <input
                            id="partner-email"
                            class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 md:text-sm"
                            type="email"
                            name="email"
                            placeholder="your@email.com"
                            autocomplete="email"
                            required
                        >
                    </div>

                    <div>
                        <label class="mb-2 block text-sm font-medium text-foreground" for="partner-message">
                            Сообщение
                        </label>
                        <textarea
                            id="partner-message"
                            class="flex min-h-[80px] w-full resize-none rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                            name="message"
                            rows="4"
                            placeholder="Напишите ваш вопрос..."
                            required
                        ></textarea>
                    </div>

                    <button
                        class="gradient-primary inline-flex w-full items-center justify-center gap-2 whitespace-nowrap rounded-md py-6 text-sm font-medium text-primary-foreground ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50"
                        type="submit"
                    >
                        Отправить заявку
                    </button>

                    <p class="text-center text-xs text-muted-foreground">
                        Нажимая кнопку, вы соглашаетесь с политикой конфиденциальности
                    </p>
                </form>
            </div>
        </div>
    </div>
</section>
