{% extends 'layouts/main.html.twig' %}

{% block content %}
    <section class="bg-background px-4 py-20 md:py-28">
        <div class="mx-auto max-w-3xl">
            <a class="mb-8 inline-flex items-center gap-2 text-sm font-semibold text-muted-foreground transition hover:text-primary" href="/">
                <span aria-hidden="true">←</span>
                На главную
            </a>
            <h1 class="font-display text-3xl font-bold leading-tight text-foreground md:text-4xl">
                {{ page.page.h1|default(page.page.title) }}
            </h1>
            {% if page.page.excerpt %}
                <p class="mt-4 text-lg leading-relaxed text-muted-foreground">{{ page.page.excerpt }}</p>
            {% endif %}
        </div>
        {% include 'sections/content/rich-text.html.twig' with { content: page.page.content|default(null) } only %}
    </section>
{% endblock %}
