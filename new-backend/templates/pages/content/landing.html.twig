{% extends 'layouts/main.html.twig' %}

{% block content %}
    <section class="bg-background px-4 py-24 md:py-32">
        <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-[1.05fr_0.95fr] md:items-center">
            <div>
                <p class="mb-4 text-sm font-semibold text-secondary">{{ page.page.title }}</p>
                <h1 class="font-display text-4xl font-bold leading-tight text-foreground md:text-6xl">
                    {{ page.page.h1|default(page.page.title) }}
                </h1>
                {% if page.page.excerpt %}
                    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground">{{ page.page.excerpt }}</p>
                {% endif %}
            </div>
            {% if page.page.ogImage %}
                <img class="aspect-[4/3] w-full rounded-lg object-cover shadow-sm" src="{{ page.page.ogImage }}" alt="{{ page.page.ogImageAlt|default(page.page.title) }}">
            {% endif %}
        </div>
    </section>

    {% include 'sections/content/rich-text.html.twig' with { content: page.page.content|default(null) } only %}
{% endblock %}
