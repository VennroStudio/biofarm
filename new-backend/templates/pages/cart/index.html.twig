{% extends 'layouts/main.html.twig' %}

{% block content %}
    <div
        data-react-island="cart-page"
        data-order-bonus-enabled="{{ site_feature('order_bonus_enabled') ? 'true' : 'false' }}"
        data-order-bonus-percent="{{ site_setting('order_bonus_percent', 5) }}"
    >
        <section class="container mx-auto px-4 py-24">
            <h1 class="font-display text-4xl font-bold text-foreground md:text-5xl">Корзина</h1>
            <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
                Проверьте выбранные товары БИОФАРМ перед оформлением заказа.
            </p>
        </section>
    </div>
{% endblock %}
