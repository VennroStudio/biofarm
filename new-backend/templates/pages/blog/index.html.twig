{% extends 'layouts/main.html.twig' %}

{% block title %}{{ page.meta.title }}{% endblock %}

{% block description %}{{ page.meta.description }}{% endblock %}

{% block content %}
    <section class="pt-32 pb-20">
        <div class="container mx-auto px-4">
            <div class="mb-12 text-center">
                <span class="mb-4 inline-block font-medium text-accent">
                    Полезные статьи
                </span>
                <h1 class="mb-4 font-display text-4xl font-bold text-foreground md:text-5xl">
                    Блог BioFarm
                </h1>
                <p class="mx-auto max-w-2xl text-lg text-muted-foreground">
                    Советы экспертов, рецепты и интересные факты о натуральных продуктах
                </p>
            </div>

            <div class="mb-12 flex flex-col gap-4 md:flex-row">
                <form class="relative max-w-md flex-1" action="/blog" method="get">
                    {% if page.selectedCategory != 'Все' %}
                        <input type="hidden" name="category" value="{{ page.selectedCategory }}">
                    {% endif %}
                    <svg class="absolute left-3 top-1/2 h-5 w-5 -translate-y-1/2 text-muted-foreground" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.3-4.3"></path>
                    </svg>
                    <input
                        type="search"
                        name="q"
                        value="{{ page.searchQuery }}"
                        placeholder="Поиск статей..."
                        class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 pl-10 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 md:text-sm"
                    >
                </form>
                <div class="flex flex-wrap gap-2">
                    {% for category in page.categories %}
                        <a
                            href="{{ page.categoryUrls[category] }}"
                            class="inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-md px-3 text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 {{ page.selectedCategory == category ? 'gradient-primary text-primary-foreground hover:bg-primary/90' : 'border border-input bg-background hover:bg-accent hover:text-accent-foreground' }}"
                        >
                            {{ category }}
                        </a>
                    {% endfor %}
                </div>
            </div>

            {% if page.posts is empty %}
                <div class="py-20 text-center">
                    <p class="text-lg text-muted-foreground">
                        Статьи не найдены. Попробуйте изменить параметры поиска.
                    </p>
                </div>
            {% else %}
                {% if page.featuredPost %}
                    <article class="mb-16">
                        <a href="/blog/{{ page.featuredPost.slug }}" class="group block">
                            <div class="grid overflow-hidden rounded-3xl bg-card shadow-premium transition-all duration-300 hover:shadow-premium-lg lg:grid-cols-2 lg:gap-8">
                                <div class="relative aspect-[4/3] overflow-hidden lg:aspect-auto">
                                    <img
                                        src="{{ page.featuredPost.image }}"
                                        alt="{{ page.featuredPost.title }}"
                                        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                                        loading="eager"
                                        decoding="async"
                                    >
                                    <span class="absolute left-6 top-6 rounded-full bg-accent px-4 py-2 font-medium text-accent-foreground">
                                        {{ page.featuredPost.category }}
                                    </span>
                                </div>
                                <div class="flex flex-col justify-center p-8 lg:p-12">
                                    <div class="mb-4 flex items-center gap-4 text-sm text-muted-foreground">
                                        <div class="flex items-center gap-2">
                                            <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M8 2v4"></path>
                                                <path d="M16 2v4"></path>
                                                <rect width="18" height="18" x="3" y="4" rx="2"></rect>
                                                <path d="M3 10h18"></path>
                                            </svg>
                                            {{ page.featuredPost.date }}
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <path d="M12 6v6l4 2"></path>
                                            </svg>
                                            {{ page.featuredPost.readTime }} мин
                                        </div>
                                    </div>
                                    <h2 class="mb-4 font-display text-2xl font-bold text-foreground transition-colors group-hover:text-primary md:text-3xl">
                                        {{ page.featuredPost.title }}
                                    </h2>
                                    <p class="mb-6 line-clamp-3 text-lg text-muted-foreground">
                                        {{ page.featuredPost.excerpt }}
                                    </p>
                                    <div class="flex items-center gap-4">
                                        {% if page.featuredPost.authorAvatar %}
                                            <img
                                                src="{{ page.featuredPost.authorAvatar }}"
                                                alt="{{ page.featuredPost.authorName }}"
                                                class="h-12 w-12 rounded-full object-cover"
                                                loading="lazy"
                                                decoding="async"
                                            >
                                        {% else %}
                                            <span class="h-12 w-12 rounded-full bg-muted" aria-hidden="true"></span>
                                        {% endif %}
                                        <span class="font-medium text-foreground">
                                            {{ page.featuredPost.authorName }}
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </article>
                {% endif %}

                <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
                    {% for post in page.otherPosts %}
                        {% include 'components/blog/grid-card.html.twig' with { post: post } only %}
                    {% endfor %}
                </div>

                {% if page.totalPages > 1 %}
                    <div class="mt-12">
                        <nav role="navigation" aria-label="pagination" class="mx-auto flex w-full justify-center">
                            <ul class="flex flex-row items-center gap-1">
                                <li>
                                    <a
                                        href="{{ page.previousPageUrl ?: '#' }}"
                                        aria-label="Go to previous page"
                                        class="inline-flex h-10 items-center justify-center gap-1 whitespace-nowrap rounded-md px-4 py-2 pl-2.5 text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 {{ page.previousPageUrl ? '' : 'pointer-events-none opacity-50' }}"
                                    >
                                        <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="m15 18-6-6 6-6"></path>
                                        </svg>
                                        <span>Previous</span>
                                    </a>
                                </li>
                                {% for item in page.paginationItems %}
                                    <li>
                                        {% if item.type == 'ellipsis' %}
                                            <span class="flex h-9 w-9 items-center justify-center" aria-hidden="true">
                                                <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <circle cx="12" cy="12" r="1"></circle>
                                                    <circle cx="19" cy="12" r="1"></circle>
                                                    <circle cx="5" cy="12" r="1"></circle>
                                                </svg>
                                                <span class="sr-only">More pages</span>
                                            </span>
                                        {% else %}
                                            <a
                                                href="{{ item.url }}"
                                                aria-current="{{ item.current ? 'page' : 'false' }}"
                                                class="inline-flex h-10 w-10 cursor-pointer items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 {{ item.current ? 'border border-input bg-background hover:bg-accent hover:text-accent-foreground' : 'hover:bg-accent hover:text-accent-foreground' }}"
                                            >
                                                {{ item.page }}
                                            </a>
                                        {% endif %}
                                    </li>
                                {% endfor %}
                                <li>
                                    <a
                                        href="{{ page.nextPageUrl ?: '#' }}"
                                        aria-label="Go to next page"
                                        class="inline-flex h-10 items-center justify-center gap-1 whitespace-nowrap rounded-md px-4 py-2 pr-2.5 text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 {{ page.nextPageUrl ? '' : 'pointer-events-none opacity-50' }}"
                                    >
                                        <span>Next</span>
                                        <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="m9 18 6-6-6-6"></path>
                                        </svg>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                {% endif %}
            {% endif %}
        </div>
    </section>
{% endblock %}
