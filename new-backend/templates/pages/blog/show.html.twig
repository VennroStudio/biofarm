{% extends 'layouts/main.html.twig' %}

{% block title %}{{ page.meta.title }}{% endblock %}

{% block description %}{{ page.meta.description }}{% endblock %}

{% block content %}
    {% if page.post %}
        <div class="pt-24">
            <div
                class="relative h-[50vh] overflow-hidden md:h-[60vh]"
                data-reveal
                data-reveal-onload="true"
                data-reveal-y="0"
                data-reveal-duration="800"
            >
                <img
                    src="{{ page.post.image }}"
                    alt="{{ page.post.title }}"
                    class="h-full w-full object-cover"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                >
                <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent"></div>
            </div>

            <div class="container relative z-10 mx-auto -mt-32 px-4">
                <article
                    class="mx-auto max-w-3xl"
                    data-reveal
                    data-reveal-onload="true"
                    data-reveal-y="40"
                    data-reveal-duration="600"
                    data-reveal-delay="200"
                >
                    <a
                        href="/blog"
                        class="mb-6 inline-flex items-center gap-2 text-muted-foreground transition-colors hover:text-foreground"
                    >
                        <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m12 19-7-7 7-7"></path>
                            <path d="M19 12H5"></path>
                        </svg>
                        Назад в блог
                    </a>

                    <span class="mb-6 inline-block rounded-full bg-accent px-4 py-2 font-medium text-accent-foreground">
                        {{ page.post.category }}
                    </span>

                    <h1 class="mb-6 font-display text-3xl font-bold leading-tight text-foreground md:text-4xl lg:text-5xl">
                        {{ page.post.title }}
                    </h1>

                    <div class="mb-8 flex flex-wrap items-center gap-6 border-b border-border pb-8">
                        <div class="text-muted-foreground">
                            <span class="font-medium">Автор: </span>
                            <span class="text-foreground">{{ page.post.authorName }}</span>
                        </div>
                        <div class="flex items-center gap-4 text-muted-foreground">
                            <div class="flex items-center gap-2">
                                <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M8 2v4"></path>
                                    <path d="M16 2v4"></path>
                                    <rect width="18" height="18" x="3" y="4" rx="2"></rect>
                                    <path d="M3 10h18"></path>
                                </svg>
                                {{ page.post.date }}
                            </div>
                            <div class="flex items-center gap-2">
                                <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <path d="M12 6v6l4 2"></path>
                                </svg>
                                {{ page.post.readTime }} мин чтения
                            </div>
                        </div>
                    </div>

                    <div class="max-w-none text-lg text-muted-foreground [&_a]:text-primary [&_a]:no-underline [&_a:hover]:underline [&_h2]:mb-6 [&_h2]:mt-12 [&_h2]:font-display [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-foreground [&_h3]:mb-4 [&_h3]:mt-8 [&_h3]:font-display [&_h3]:text-xl [&_h3]:font-bold [&_h3]:text-foreground [&_li]:my-2 [&_ol]:my-6 [&_ol]:text-muted-foreground [&_p:first-child]:mt-0 [&_p:not(:first-child)]:mt-0 [&_p]:mb-6 [&_p]:leading-relaxed [&_p]:text-muted-foreground [&_strong]:font-semibold [&_strong]:text-foreground [&_ul]:my-6 [&_ul]:text-muted-foreground">
                        {{ page.post.content|raw }}
                    </div>
                </article>

                {% if page.relatedPosts is not empty %}
                    <section
                        class="mx-auto mt-20 max-w-5xl pb-20"
                        data-reveal
                        data-reveal-y="40"
                        data-reveal-duration="600"
                        data-reveal-delay="400"
                    >
                        <h2 class="mb-8 font-display text-2xl font-bold text-foreground md:text-3xl">
                            Похожие статьи
                        </h2>
                        <div class="grid gap-6 md:grid-cols-3">
                            {% for relatedPost in page.relatedPosts %}
                                <a href="/blog/{{ relatedPost.slug }}" class="group">
                                    <article class="overflow-hidden rounded-2xl bg-card shadow-premium transition-all duration-300 hover:shadow-premium-lg">
                                        <div class="relative aspect-[4/3] overflow-hidden">
                                            <img
                                                src="{{ relatedPost.image }}"
                                                alt="{{ relatedPost.title }}"
                                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                                                loading="lazy"
                                                decoding="async"
                                            >
                                        </div>
                                        <div class="p-5">
                                            <div class="mb-2 flex items-center gap-2 text-sm text-muted-foreground">
                                                <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M8 2v4"></path>
                                                    <path d="M16 2v4"></path>
                                                    <rect width="18" height="18" x="3" y="4" rx="2"></rect>
                                                    <path d="M3 10h18"></path>
                                                </svg>
                                                {{ relatedPost.date }}
                                            </div>
                                            <h3 class="line-clamp-2 font-bold text-foreground transition-colors group-hover:text-primary">
                                                {{ relatedPost.title }}
                                            </h3>
                                        </div>
                                    </article>
                                </a>
                            {% endfor %}
                        </div>
                    </section>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="pb-20 pt-32">
            <div class="container mx-auto px-4 text-center">
                <h1 class="mb-4 font-display text-3xl font-bold text-foreground">
                    Статья не найдена
                </h1>
                <p class="mb-8 text-muted-foreground">
                    К сожалению, запрашиваемая статья не существует.
                </p>
                <a
                    href="/blog"
                    class="inline-flex h-10 items-center justify-center gap-2 whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground ring-offset-background transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                >
                    <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m12 19-7-7 7-7"></path>
                        <path d="M19 12H5"></path>
                    </svg>
                    Вернуться в блог
                </a>
            </div>
        </div>
    {% endif %}
{% endblock %}
