{% extends 'layouts/main.html.twig' %}

{% block title %}{{ page.meta.title }}{% endblock %}

{% block description %}{{ page.meta.description }}{% endblock %}

{% block content %}
    {% include 'sections/home/hero.html.twig' only %}
    {% include 'sections/home/features.html.twig' only %}
    {% include 'sections/product/catalog.html.twig' with {
        products: page.products,
        categories: page.categories,
        categoriesTotal: page.categoriesTotal,
        selectedCategory: page.selectedCategory,
        basePath: '/',
        showAllLink: true,
    } only %}
    {% include 'sections/home/video.html.twig' only %}
    {% include 'sections/home/blog.html.twig' with {
        posts: page.blogPosts,
    } only %}
    {% include 'sections/home/about.html.twig' only %}
    {% include 'sections/home/marketplaces.html.twig' only %}
    {% include 'sections/home/reviews.html.twig' with {
        reviews: page.reviews,
    } only %}
    {% include 'sections/home/contacts.html.twig' only %}
{% endblock %}
