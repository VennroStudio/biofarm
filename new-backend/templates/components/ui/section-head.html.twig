<div class="mb-6 flex items-end justify-between gap-5 max-sm:flex-col max-sm:items-start">
    <div>
        {% if eyebrow is defined and eyebrow %}
            <p class="text-xs font-black uppercase tracking-[0.12em] text-primary">{{ eyebrow }}</p>
        {% endif %}
        <h2 class="mt-2 font-display text-3xl font-bold leading-tight text-foreground md:text-4xl">{{ title }}</h2>
    </div>

    {% if action is defined and action %}
        {% include 'components/ui/link.html.twig' with {
            class: action.class|default('inline-flex min-h-11 items-center justify-center rounded-lg border border-border bg-transparent px-5 text-sm font-bold text-primary transition-colors hover:bg-secondary'),
            href: action.href,
            label: action.label,
            external: action.external|default(false),
        } only %}
    {% endif %}
</div>
