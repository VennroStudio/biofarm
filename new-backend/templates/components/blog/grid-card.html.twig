<article>
    <a href="/blog/{{ post.slug }}" class="group block h-full">
        <div class="flex h-full flex-col overflow-hidden rounded-2xl bg-card shadow-premium transition-all duration-300 hover:shadow-premium-lg">
            <div class="relative aspect-[4/3] overflow-hidden">
                <img
                    src="{{ post.image }}"
                    alt="{{ post.title }}"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                >
                <span class="absolute left-4 top-4 rounded-full bg-accent px-3 py-1 text-sm font-medium text-accent-foreground">
                    {{ post.category }}
                </span>
            </div>
            <div class="flex flex-1 flex-col p-6">
                <div class="mb-3 flex items-center gap-4 text-sm text-muted-foreground">
                    <div class="flex items-center gap-1">
                        <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M8 2v4"></path>
                            <path d="M16 2v4"></path>
                            <rect width="18" height="18" x="3" y="4" rx="2"></rect>
                            <path d="M3 10h18"></path>
                        </svg>
                        {{ post.date }}
                    </div>
                    <div class="flex items-center gap-1">
                        <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M12 6v6l4 2"></path>
                        </svg>
                        {{ post.readTime }} мин
                    </div>
                </div>
                <h3 class="mb-3 line-clamp-2 text-lg font-bold text-foreground transition-colors group-hover:text-primary">
                    {{ post.title }}
                </h3>
                <p class="mb-4 line-clamp-2 flex-1 text-sm text-muted-foreground">
                    {{ post.excerpt }}
                </p>
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        {% if post.authorAvatar %}
                            <img
                                src="{{ post.authorAvatar }}"
                                alt="{{ post.authorName }}"
                                class="h-8 w-8 rounded-full object-cover"
                                loading="lazy"
                                decoding="async"
                            >
                        {% else %}
                            <span class="h-8 w-8 rounded-full bg-muted" aria-hidden="true"></span>
                        {% endif %}
                        <span class="text-sm text-muted-foreground">
                            {{ post.authorName }}
                        </span>
                    </div>
                    <svg class="h-5 w-5 text-primary opacity-0 transition-opacity group-hover:opacity-100" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"></path>
                        <path d="m12 5 7 7-7 7"></path>
                    </svg>
                </div>
            </div>
        </div>
    </a>
</article>
