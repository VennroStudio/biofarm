<article
    class="relative rounded-2xl bg-card p-6 shadow-premium"
    data-review-card
    data-review-index="{{ index }}"
    {% if index >= 3 %}hidden{% endif %}
>
    <svg class="absolute right-6 top-6 h-8 w-8 text-primary/10" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.76-2-2-2H4c-1.25 0-2 .75-2 2v6c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"></path>
        <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2-2-2h-4c-1.25 0-2 .75-2 2v6c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"></path>
    </svg>

    <div class="mb-4 flex items-center gap-4">
        <img
            src="{{ review.avatar }}"
            alt="{{ review.name }}"
            class="h-12 w-12 rounded-full object-cover"
            loading="lazy"
            decoding="async"
        >
        <div>
            <h4 class="font-bold text-foreground">{{ review.name }}</h4>
            <p class="text-sm text-muted-foreground">{{ review.product }}</p>
        </div>
    </div>

    <div class="mb-4 flex gap-1" aria-label="Оценка {{ review.rating }} из 5">
        {% for starIndex in 0..4 %}
            <svg
                class="h-4 w-4 {{ starIndex < review.rating ? 'fill-accent text-accent' : 'text-muted-foreground' }}"
                aria-hidden="true"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.12 2.12 0 0 0 1.595 1.16l5.166.751a.53.53 0 0 1 .294.904l-3.738 3.644a2.12 2.12 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.12 2.12 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.12 2.12 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.75a2.12 2.12 0 0 0 1.596-1.16z"></path>
            </svg>
        {% endfor %}
    </div>

    <p class="mb-4 line-clamp-3 text-muted-foreground">
        {{ review.text }}
    </p>

    {% if review.images is not empty %}
        <div class="mb-4 flex gap-2 overflow-x-auto">
            {% for image in review.images %}
                <button
                    type="button"
                    class="flex-shrink-0 rounded-lg transition-opacity hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                    aria-label="Открыть фото к отзыву {{ loop.index }}"
                    data-review-image
                    data-lightbox-image="{{ image }}"
                >
                    <img
                        src="{{ image }}"
                        alt="Фото к отзыву {{ loop.index }}"
                        class="h-16 w-16 rounded-lg object-cover"
                        loading="lazy"
                        decoding="async"
                    >
                </button>
            {% endfor %}
        </div>
    {% endif %}
</article>
