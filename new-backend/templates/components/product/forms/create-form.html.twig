{% set fields = [
    { label: 'Title', name: 'title', value: 'Template product', required: true },
    { label: 'Price', name: 'price', type: 'number', step: '0.01', value: '199.90', required: true },
    { label: 'Description', name: 'description', value: 'Новый товар после миграции базы данных', multiline: true, required: true },
    { label: 'Category', name: 'category', value: 'demo', required: true },
    { label: 'Brand', name: 'brand', value: 'Biofarm', required: true },
    { label: 'Stock', name: 'stock', type: 'number', value: '12', required: true },
    { label: 'Image', name: 'image', value: 'https://biofarm.store/uploads/images/index/poster.webp', required: true },
] %}

<form class="command-form" method="post" action="/products/create">
    {% include 'components/ui/csrf-field.html.twig' with { action: 'products.create' } only %}

    {% for field in fields %}
        {% include 'components/ui/form-field.html.twig' with { field: field } only %}
    {% endfor %}

    <button class="button" type="submit">Создать</button>
</form>
