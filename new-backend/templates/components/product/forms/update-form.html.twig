{% set fields = [
    { label: 'ID', name: 'id', type: 'number', value: '1', required: true },
    { label: 'Title', name: 'title', value: 'Updated template product' },
    { label: 'Price', name: 'price', type: 'number', step: '0.01', value: '229.90' },
    { label: 'Stock', name: 'stock', type: 'number', value: '18' },
    { label: 'Brand', name: 'brand', value: 'Biofarm' },
] %}

<form class="command-form" method="post" action="/products/update">
    {% include 'components/ui/csrf-field.html.twig' with { action: 'products.update' } only %}

    {% for field in fields %}
        {% include 'components/ui/form-field.html.twig' with { field: field } only %}
    {% endfor %}

    <button class="button" type="submit">Обновить</button>
</form>
