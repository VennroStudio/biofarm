<div data-product-counter-root>
    <div
        class="flex flex-wrap items-center gap-2"
        data-product-counter
        data-product-id="{{ product.id }}"
        data-product-title="{{ product.title }}"
        data-product-price="{{ product.price }}"
        data-product-quantity="1"
    >
        <button
            class="grid h-10 w-10 place-items-center rounded-lg border border-primary bg-primary/10 font-bold text-primary disabled:cursor-not-allowed disabled:opacity-55"
            type="button"
            data-counter-decrement
            data-variant="light"
            aria-label="Уменьшить количество {{ product.title }}"
            disabled
        >-</button>
        <span class="min-w-7 text-center font-bold" data-counter-quantity aria-live="polite">1</span>
        <button
            class="grid h-10 w-10 place-items-center rounded-lg border border-primary bg-primary/10 font-bold text-primary disabled:cursor-not-allowed disabled:opacity-55"
            type="button"
            data-counter-increment
            data-variant="light"
            aria-label="Увеличить количество {{ product.title }}"
        >+</button>
        <output class="inline-grid min-h-10 place-items-center rounded-lg border border-primary bg-primary px-4 font-bold text-primary-foreground" data-counter-total aria-live="polite">{{ product.price|money }}</output>
    </div>

    <div
        data-react-island="product-counter"
        data-counter-selector="[data-product-counter]"
        hidden
    ></div>
</div>
