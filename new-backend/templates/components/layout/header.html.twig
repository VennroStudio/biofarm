<header
    class="fixed top-0 left-0 right-0 z-50 bg-primary/90 backdrop-blur-sm transition-all duration-300"
    data-site-header-root
>
    <div class="container mx-auto px-4">
        <div class="flex h-20 items-center justify-between">
        <a class="flex items-center gap-2" href="/" aria-label="{{ site.brand.title }}">
            {% if site.brand.logoUrl is defined and site.brand.logoUrl %}
                {{ optimized_image(site.brand.logoUrl, site.brand.title, {
                    class: 'h-12 w-auto object-contain transition-[filter] duration-300',
                    width: 172,
                    height: 64,
                    loading: 'eager',
                    fetchpriority: 'high',
                    decoding: 'async'
                }) }}
            {% else %}
                <span class="grid h-11 w-11 place-items-center rounded-lg bg-primary-foreground text-primary font-black">{{ site.brand.mark }}</span>
                <span class="block text-primary-foreground">
                    <strong>{{ site.brand.title }}</strong>
                    <small class="block text-xs text-primary-foreground/70">{{ site.brand.subtitle }}</small>
                </span>
            {% endif %}
        </a>

        <nav class="hidden items-center gap-8 lg:flex" aria-label="Основная навигация">
            {% for item in site.navigation %}
                {% include 'components/ui/link.html.twig' with {
                    class: 'text-sm font-medium text-white/90 transition-colors hover:text-accent',
                    href: item.href,
                    label: item.label,
                    external: item.external|default(false),
                } only %}
            {% endfor %}
        </nav>

        <div class="hidden items-center gap-4 lg:flex">
            {% if site_feature('cart_enabled') %}
                <a
                    href="/cart"
                    class="relative inline-flex h-11 w-11 items-center justify-center rounded-lg text-white transition-colors hover:text-accent"
                    data-cart-link
                    aria-label="Корзина"
                >
                    <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="8" cy="21" r="1"></circle>
                        <circle cx="19" cy="21" r="1"></circle>
                        <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
                    </svg>
                    <span
                        class="absolute -right-1 -top-1 hidden h-5 min-w-5 items-center justify-center rounded-full bg-destructive px-1 text-xs font-bold text-destructive-foreground"
                        data-cart-count
                    ></span>
                </a>
            {% endif %}
            <a class="gradient-primary inline-flex min-h-11 items-center justify-center rounded-lg px-5 text-sm font-bold text-primary-foreground transition-opacity hover:opacity-95" href="/catalog">
                Заказать
            </a>
        </div>

        <details class="group lg:hidden [&>nav]:block [&>summary::-webkit-details-marker]:hidden">
            <summary
                class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-lg text-white"
                aria-label="Открыть меню"
            >
                <span class="relative block h-5 w-6">
                    <span class="absolute left-0 top-0 h-0.5 w-6 rounded-full bg-current transition-transform duration-200 group-open:translate-y-2 group-open:rotate-45"></span>
                    <span class="absolute left-0 top-2 h-0.5 w-6 rounded-full bg-current transition-opacity duration-200 group-open:opacity-0"></span>
                    <span class="absolute left-0 top-4 h-0.5 w-6 rounded-full bg-current transition-transform duration-200 group-open:-translate-y-2 group-open:-rotate-45"></span>
                </span>
            </summary>

            <nav
                class="pointer-events-none absolute left-0 right-0 top-20 max-h-0 overflow-hidden border-t border-border bg-background opacity-0 shadow-premium transition-[max-height,opacity] duration-300 ease-out group-open:pointer-events-auto group-open:max-h-[440px] group-open:opacity-100 lg:hidden"
                id="site-header-mobile-menu"
                aria-label="Мобильная навигация"
            >
                <div class="container mx-auto flex flex-col gap-4 px-4 py-6">
                    {% for item in site.navigation %}
                        {% include 'components/ui/link.html.twig' with {
                            class: 'py-2 text-lg font-medium text-foreground transition-colors hover:text-primary',
                            href: item.href,
                            label: item.label,
                            external: item.external|default(false),
                        } only %}
                    {% endfor %}
                    {% if site_feature('cart_enabled') %}
                        <div class="border-t border-border pt-4">
                            <a
                                href="/cart"
                                class="gradient-primary inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-lg px-5 text-sm font-bold text-primary-foreground"
                                data-cart-link
                            >
                                <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="8" cy="21" r="1"></circle>
                                    <circle cx="19" cy="21" r="1"></circle>
                                    <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
                                </svg>
                                <span>Корзина</span>
                                <span data-cart-count></span>
                            </a>
                        </div>
                    {% endif %}
                </div>
            </nav>
        </details>
        </div>
    </div>

    <div
        data-react-island="site-header"
        data-root-selector="[data-site-header-root]"
        hidden
    ></div>
</header>
