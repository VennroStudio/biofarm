{
    "name": "biofarm/slim-frontend",
    "description": "Slim frontend renderer with Twig pages and React islands.",
    "type": "project",
    "license": "proprietary",
    "config": {
        "sort-packages": true
    },
    "require": {
        "php": ">=8.4",
        "monolog/monolog": "^3.0",
        "php-di/php-di": "^7.1",
        "slim/psr7": "^1.8",
        "slim/slim": "^4.15",
        "symfony/http-client": "^8.0",
        "twig/twig": "^3.23",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.93",
        "overtrue/phplint": "^9.7",
        "rector/rector": "^2.3",
        "roave/security-advisories": "dev-master",
        "vimeo/psalm": "^6.14"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Components/env.php"
        ]
    },
    "scripts": {
        "check": [
            "@lint",
            "rector process --dry-run",
            "php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes --dry-run --diff",
            "@psalm"
        ],
        "php-cs-fixer": "php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes",
        "lint": "phplint",
        "psalm": "psalm",
        "rector": "rector process"
    }
}
