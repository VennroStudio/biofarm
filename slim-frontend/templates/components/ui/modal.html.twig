<div
    class="modal"
    data-modal="{{ id }}"
    role="presentation"
    hidden
>
    <div
        class="modal__dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="{{ id }}-title"
        tabindex="-1"
    >
        <div class="modal__head">
            <div>
                {% if eyebrow is defined and eyebrow %}
                    <p class="eyebrow" data-modal-eyebrow>{{ eyebrow }}</p>
                {% else %}
                    <p class="eyebrow" data-modal-eyebrow hidden></p>
                {% endif %}
                <h3 id="{{ id }}-title" data-modal-title>{{ title }}</h3>
            </div>
            <button type="button" aria-label="Close modal" data-modal-close>x</button>
        </div>

        <div class="modal__body" data-modal-body>
            {% block body %}{% endblock %}
        </div>

        {% if block('actions') is defined %}
            <div class="modal__actions" data-modal-actions>
                {% block actions %}{% endblock %}
            </div>
        {% endif %}
    </div>
</div>
