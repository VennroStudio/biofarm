<div class="section__head">
    <div>
        {% if eyebrow is defined and eyebrow %}
            <p class="eyebrow">{{ eyebrow }}</p>
        {% endif %}
        <h2>{{ title }}</h2>
    </div>

    {% if action is defined and action %}
        {% include 'components/ui/link.html.twig' with {
            class: 'button ' ~ (action.class|default('button--ghost')),
            href: action.href,
            label: action.label,
            external: action.external|default(false),
        } only %}
    {% endif %}
</div>
