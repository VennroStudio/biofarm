{% set fields = [
    { label: 'Title', name: 'title', value: 'Template product', required: true },
    { label: 'Price', name: 'price', type: 'number', step: '0.01', value: '199.90', required: true },
    { label: 'Description', name: 'description', value: 'Created from Slim frontend command handler', multiline: true, required: true },
    { label: 'Category', name: 'category', value: 'demo', required: true },
    { label: 'Brand', name: 'brand', value: 'Biofarm', required: true },
    { label: 'Stock', name: 'stock', type: 'number', value: '12', required: true },
    { label: 'Image', name: 'image', value: 'https://fakeapi.net/images/products/smartphone.jpg', required: true },
] %}

<form class="command-form" method="post" action="/products/create" data-product-command-form data-command-title="Create product">
    {% include 'components/ui/csrf-field.html.twig' with { action: 'products.create' } only %}
    {% include 'components/ui/http-endpoint.html.twig' with {
        class: 'command-form__head',
        method: 'POST',
        endpoint: '/products/create',
    } only %}

    {% for field in fields %}
        {% include 'components/ui/form-field.html.twig' with { field: field } only %}
    {% endfor %}

    <button class="button" type="submit">Create</button>
</form>
