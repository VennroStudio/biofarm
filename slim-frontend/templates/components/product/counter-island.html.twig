<div
    class="island-counter"
    data-product-counter
    data-product-id="{{ product.id }}"
    data-product-title="{{ product.title }}"
    data-product-price="{{ product.price }}"
    data-product-quantity="1"
>
    <button
        type="button"
        data-counter-decrement
        data-variant="light"
        aria-label="Decrease {{ product.title }}"
        disabled
    >-</button>
    <span data-counter-quantity aria-live="polite">1</span>
    <button
        type="button"
        data-counter-increment
        data-variant="light"
        aria-label="Increase {{ product.title }}"
    >+</button>
    <output data-counter-total aria-live="polite">{{ product.price|money }}</output>
</div>

<div data-react-island="product-counter" hidden></div>
