{% if categories %}
    <section class="category-strip" aria-label="Loaded categories">
        <a
            href="/#catalog"
            {% if selectedCategory is not defined or selectedCategory is null %}aria-current="true"{% endif %}
        >
            All
            <span>{{ categoriesTotal }}</span>
        </a>
        {% for category in categories %}
            <a
                href="/?category={{ category.name|url_encode }}#catalog"
                {% if selectedCategory is defined and selectedCategory == category.name %}aria-current="true"{% endif %}
            >
                {{ category.name }}
                <span>{{ category.productsCount }}</span>
            </a>
        {% endfor %}
    </section>
{% endif %}
