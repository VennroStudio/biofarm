{% if product %}
    <section class="featured-product">
        <div>
            <p class="eyebrow">Featured product</p>
            <h2>{{ product.title }}</h2>
            <p>{{ product.description }}</p>
            <dl class="featured-product__facts">
                <div>
                    <dt>Brand</dt>
                    <dd>{{ product.brand }}</dd>
                </div>
                <div>
                    <dt>Rating</dt>
                    <dd>{{ product.ratingRate|rating }} · {{ product.ratingCount }}</dd>
                </div>
                <div>
                    <dt>Stock</dt>
                    <dd>{{ product.stock }}</dd>
                </div>
            </dl>
            {% include 'components/product/counter-island.html.twig' with { product: product } only %}
        </div>
        <img src="{{ product.image }}" alt="{{ product.title }}">
    </section>
{% endif %}
