<section class="section" id="product-commands">
    {% include 'components/ui/section-head.html.twig' with {
        eyebrow: 'Product commands',
        title: 'Create / Update / Delete через Product handlers',
    } only %}

    <div class="command-forms">
        <form class="command-form" method="post" action="/products/create">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('products.create') }}">
            <div class="command-form__head">
                <span>POST</span>
                <strong>/products/create</strong>
            </div>

            <label>
                <span>Title</span>
                <input name="title" value="Template product" required>
            </label>
            <label>
                <span>Price</span>
                <input name="price" type="number" step="0.01" value="199.90" required>
            </label>
            <label>
                <span>Description</span>
                <textarea name="description" required>Created from Slim frontend command handler</textarea>
            </label>
            <label>
                <span>Category</span>
                <input name="category" value="demo" required>
            </label>
            <label>
                <span>Brand</span>
                <input name="brand" value="Biofarm" required>
            </label>
            <label>
                <span>Stock</span>
                <input name="stock" type="number" value="12" required>
            </label>
            <label>
                <span>Image</span>
                <input name="image" value="https://fakeapi.net/images/products/smartphone.jpg" required>
            </label>

            <button class="button" type="submit">Create</button>
        </form>

        <form class="command-form" method="post" action="/products/update">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('products.update') }}">
            <div class="command-form__head">
                <span>PATCH</span>
                <strong>/products/update</strong>
            </div>

            <label>
                <span>ID</span>
                <input name="id" type="number" value="1" required>
            </label>
            <label>
                <span>Title</span>
                <input name="title" value="Updated template product">
            </label>
            <label>
                <span>Price</span>
                <input name="price" type="number" step="0.01" value="229.90">
            </label>
            <label>
                <span>Stock</span>
                <input name="stock" type="number" value="18">
            </label>
            <label>
                <span>Brand</span>
                <input name="brand" value="Biofarm">
            </label>

            <button class="button" type="submit">Update</button>
        </form>

        <form class="command-form" method="post" action="/products/delete">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('products.delete') }}">
            <div class="command-form__head">
                <span>DELETE</span>
                <strong>/products/delete</strong>
            </div>

            <label>
                <span>ID</span>
                <input name="id" type="number" value="1" required>
            </label>

            <button class="button button--secondary" type="submit">Delete</button>
        </form>
    </div>
</section>
