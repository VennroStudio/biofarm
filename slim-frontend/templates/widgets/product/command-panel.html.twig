<section class="section" id="product-commands">
    {% include 'components/ui/section-head.html.twig' with {
        eyebrow: 'Product commands',
        title: 'Create / Update / Delete через Product handlers',
    } only %}

    <div class="command-forms">
        {% include 'components/product/forms/create-form.html.twig' only %}
        {% include 'components/product/forms/update-form.html.twig' only %}
        {% include 'components/product/forms/delete-form.html.twig' only %}
    </div>

    <div class="command-panel-feedback" data-command-feedback aria-live="polite">
        <div class="command-panel-status" data-command-status hidden>
            <strong data-command-status-title></strong>
            <span>Sending command...</span>
        </div>

        <div class="command-panel-toast" data-command-toast hidden>
            <span data-command-toast-message></span>
            <button type="button" data-command-toast-details>Details</button>
        </div>
    </div>

    <div
        data-react-island="product-command-panel"
        data-panel-selector="#product-commands"
        data-feedback-selector="[data-command-feedback]"
        data-modal-selector="[data-modal='product-command-result']"
    ></div>

    {% embed 'components/ui/modal.html.twig' with {
        id: 'product-command-result',
        eyebrow: 'Product command',
        title: 'Command result',
    } only %}
        {% block body %}
            <div class="command-modal__message" data-command-result-message>
                <strong data-command-result-status></strong>
                <span data-command-result-text></span>
            </div>

            <article class="command-modal__product" data-command-result-product hidden>
                <img
                    src=""
                    alt=""
                    loading="lazy"
                    decoding="async"
                    data-command-product-image
                >
                <div>
                    <span data-command-product-brand></span>
                    <strong data-command-product-title></strong>
                    <p data-command-product-description></p>
                    <div>
                        <b data-command-product-price></b>
                        <small data-command-product-meta></small>
                    </div>
                </div>
            </article>

            <div class="command-modal__delete" data-command-result-delete hidden>
                <strong data-command-delete-title></strong>
                <span data-command-delete-status></span>
                <p data-command-delete-message></p>
            </div>
        {% endblock %}
    {% endembed %}
</section>
